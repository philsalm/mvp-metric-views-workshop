{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Components",
      "queryLines": [
        "SELECT `measurement_year`, `line_of_business`, MEASURE(`compliant_members`) AS compliant_members, MEASURE(`eligible_members`) AS eligible_members, MEASURE(`open_care_gaps`) AS open_care_gaps FROM ai_dev_kit_demo_3_catalog.mvp_quality_workshop.quality_measures_mv GROUP BY `measurement_year`, `line_of_business` "
      ]
    },
    {
      "name": "ds_by_measure",
      "displayName": "Compliance by Measure",
      "queryLines": [
        "SELECT `measurement_year`, `line_of_business`, `measure_name`, MEASURE(`compliance_rate`)*100 AS compliance_rate_pct FROM ai_dev_kit_demo_3_catalog.mvp_quality_workshop.quality_measures_mv GROUP BY `measurement_year`, `line_of_business`, `measure_name` "
      ]
    },
    {
      "name": "ds_by_lob",
      "displayName": "Compliance by Line of Business",
      "queryLines": [
        "SELECT `measurement_year`, `line_of_business`, MEASURE(`compliance_rate`)*100 AS compliance_rate_pct FROM ai_dev_kit_demo_3_catalog.mvp_quality_workshop.quality_measures_mv GROUP BY `measurement_year`, `line_of_business` "
      ]
    },
    {
      "name": "ds_by_region",
      "displayName": "Open Care Gaps by Region",
      "queryLines": [
        "SELECT `measurement_year`, `line_of_business`, `region`, MEASURE(`open_care_gaps`) AS open_care_gaps FROM ai_dev_kit_demo_3_catalog.mvp_quality_workshop.quality_measures_mv GROUP BY `measurement_year`, `line_of_business`, `region` "
      ]
    },
    {
      "name": "ds_yoy",
      "displayName": "Compliance YoY by Quality Domain",
      "queryLines": [
        "SELECT `measurement_year`, `line_of_business`, `quality_domain`, MEASURE(`compliance_rate`)*100 AS compliance_rate_pct FROM ai_dev_kit_demo_3_catalog.mvp_quality_workshop.quality_measures_mv GROUP BY `measurement_year`, `line_of_business`, `quality_domain` "
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": [
                "# MVP Health Care — Quality Measures (HEDIS) [Workshop]"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {
              "lines": [
                "HEDIS quality measure performance — compliance rates, open care gaps, and eligible membership. Source: quality_measures_mv (Unity Catalog metric view)."
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "kpi-compliance",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpi",
                  "fields": [
                    {
                      "name": "compliance_rate_pct",
                      "expression": "SUM(`compliant_members`)/SUM(`eligible_members`)*100"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "compliance_rate_pct",
                  "displayName": "Compliance Rate (%)",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 1
                    }
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Compliance Rate (%)"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
